{
  "name": "prjct-cli",
  "version": "0.7.0",
  "description": "Built for Claude - Ship fast, track progress, stay focused. Developer momentum tool for indie hackers.",
  "main": "core/index.js",
  "bin": {
    "prjct": "bin/prjct"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "install-global": "./scripts/install.sh",
    "test": "echo 'No tests configured'",
    "validate": "node scripts/validate-commands.js",
    "lint": "eslint \"**/*.js\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"website/**\"",
    "lint:fix": "eslint \"**/*.js\" --fix --ignore-pattern \"node_modules/**\" --ignore-pattern \"website/**\"",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" --config .config/.prettierrc --ignore-path .config/.prettierignore",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\" --config .config/.prettierrc --ignore-path .config/.prettierignore",
    "website:dev": "cd website && npm run dev",
    "website:build": "cd website && npm run build",
    "website:preview": "cd website && npm run preview",
    "website:install": "cd website && npm install"
  },
  "keywords": [
    "claude-code",
    "claude-desktop",
    "developer-momentum",
    "indie-hacker",
    "ship-fast",
    "ai-assistant",
    "productivity",
    "developer-tools",
    "no-bs",
    "focus"
  ],
  "author": "prjct.app",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jlopezlira/prjct-cli.git"
  },
  "bugs": {
    "url": "https://github.com/jlopezlira/prjct-cli/issues"
  },
  "homepage": "https://prjct.app",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "core/",
    "templates/",
    "scripts/install.sh",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CLAUDE.md"
  ],
  "trustedDependencies": [
    "chalk",
    "prompts"
  ]
}
