{
  "name": "prjct-cli",
  "version": "3.59.0",
  "description": "Project memory and workflow context for AI coding agents.",
  "main": "dist/bin/prjct.mjs",
  "bin": {
    "prjct": "bin/prjct.cjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "build:node": "node scripts/build.js",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "prepare": "lefthook install",
    "update-commands": "bun -e \"const installer = require('./core/infrastructure/command-installer'); installer.syncCommands().then(r => console.log('Commands updated:', r)).catch(e => console.error('Error:', e.message))\"",
    "install-global": "./scripts/install.sh",
    "update": "./scripts/update.sh",
    "test": "bun test",
    "test:unit": "bun test --path-ignore-patterns='**/e2e/**'",
    "test:fast": "bun test --path-ignore-patterns='**/e2e/**' --dots",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit -p core/tsconfig.json",
    "typecheck:watch": "tsc --noEmit -p core/tsconfig.json --watch",
    "validate": "bun scripts/validate-commands.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "knip": "knip",
    "lint:meta": "bun core/cli/lint-meta-commentary.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test:e2e": "bun test core/__tests__/e2e/",
    "bench:ab": "bun scripts/bench-ab.ts",
    "bench:weak-model": "bun scripts/bench-weak-model.ts",
    "demo:weak-vs-frontier": "bun scripts/demo-weak-vs-frontier.ts",
    "harness:score": "bun bin/prjct.ts harness score --md",
    "gate:dominance": "bun test core/__tests__/services/weak-model-bench.test.ts core/__tests__/services/weak-frontier-demo.test.ts core/__tests__/services/harness-score.test.ts core/__tests__/services/dynasty-outcomes.test.ts core/__tests__/services/content-bound-stamp.test.ts core/__tests__/services/sot-bind.test.ts core/__tests__/services/trap-surface-slo.test.ts core/__tests__/services/impact-ready.test.ts core/__tests__/services/delivery-geometry.test.ts core/__tests__/services/cycle-budget-card.test.ts core/__tests__/services/land-rho.test.ts core/__tests__/services/one-breath-install.test.ts core/__tests__/services/doctor-heal.test.ts && bun run bench:weak-model && bun run demo:weak-vs-frontier"
  },
  "keywords": [
    "claude-code",
    "gemini-cli",
    "ai-agents",
    "context-layer",
    "developer-tools",
    "ai-assistant",
    "productivity",
    "mcp",
    "llm",
    "coding-agents"
  ],
  "author": {
    "name": "Juan José López Lira",
    "email": "jlopezlira@gmail.com",
    "url": "https://prjct.app"
  },
  "contributors": [
    {
      "name": "prjct.app contributors"
    }
  ],
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  ],
  "dependencies": {
    "@clack/prompts": "1.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "chalk": "4.1.2",
    "chokidar": "5.0.0",
    "jsonc-parser": "3.3.1",
    "zod": "3.25.76"
  },
  "overrides": {
    "path-to-regexp": "8.4.0",
    "brace-expansion": "5.0.5",
    "fast-uri": ">=3.1.2",
    "hono": "4.12.27",
    "ip-address": ">=10.1.1",
    "qs": "6.15.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/bun": "latest",
    "@types/chokidar": "2.1.7",
    "@types/node": "^22",
    "esbuild": "0.28.1",
    "knip": "6.3.1",
    "lefthook": "2.1.0",
    "typescript": "5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prjct-app/cli.git"
  },
  "bugs": {
    "url": "https://github.com/prjct-app/cli/issues"
  },
  "homepage": "https://cli.prjct.app",
  "packageManager": "bun@1.2.23",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=22.5.0"
  },
  "files": [
    "assets/",
    "bin/prjct",
    "bin/prjct.cjs",
    "dist/",
    "templates/",
    "scripts/install.sh",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "prepublishOnly": "node scripts/build.js"
}
