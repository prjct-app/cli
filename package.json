{
  "name": "prjct-cli",
  "version": "0.33.4",
  "description": "Built for Claude - Ship fast, track progress, stay focused. Developer momentum tool for indie hackers.",
  "main": "core/index.ts",
  "bin": {
    "prjct": "bin/prjct"
  },
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "build:shared": "bun run --filter '@prjct/shared' build",
    "build:node": "node scripts/build.js",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "postinstall": "node scripts/postinstall.js",
    "update-commands": "bun -e \"const installer = require('./core/infrastructure/command-installer'); installer.syncCommands().then(r => console.log('Commands updated:', r)).catch(e => console.error('Error:', e.message))\"",
    "install-global": "./scripts/install.sh",
    "update": "./scripts/update.sh",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit -p core/tsconfig.json",
    "typecheck:watch": "tsc --noEmit -p core/tsconfig.json --watch",
    "validate": "bun scripts/validate-commands.js",
    "lint": "eslint . --ignore-pattern node_modules",
    "lint:fix": "eslint . --fix --ignore-pattern node_modules",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" --config .config/.prettierrc --ignore-path .config/.prettierignore",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\" --config .config/.prettierrc --ignore-path .config/.prettierignore"
  },
  "keywords": [
    "claude-code",
    "claude-desktop",
    "developer-momentum",
    "indie-hacker",
    "ship-fast",
    "ai-assistant",
    "productivity",
    "developer-tools",
    "no-bs",
    "focus"
  ],
  "author": "prjct.app",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@linear/sdk": "^29.0.0",
    "chalk": "^4.1.2",
    "esbuild": "^0.25.0",
    "glob": "^10.3.10",
    "hono": "^4.11.3",
    "jsonc-parser": "^3.3.1",
    "lightningcss": "^1.30.2",
    "prompts": "^2.4.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jlopezlira/prjct-cli.git"
  },
  "bugs": {
    "url": "https://github.com/jlopezlira/prjct-cli/issues"
  },
  "homepage": "https://prjct.app",
  "packageManager": "bun@1.2.23",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "files": [
    "assets/",
    "bin/",
    "core/",
    "dist/",
    "packages/shared/",
    "templates/",
    "scripts/postinstall.js",
    "scripts/build.js",
    "scripts/install.sh",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CLAUDE.md"
  ],
  "trustedDependencies": [
    "chalk",
    "prompts"
  ]
}
